# WonderwallAi API Server — Environment Variables
# Copy to .env and fill in values

# Server
ENVIRONMENT=development          # "development" or "production"
PORT=8080

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./wonderwall_server.db
# DATABASE_URL=postgresql://user:pass@host:5432/wonderwall

# Groq API key (powers the Sentinel LLM classifier)
GROQ_API_KEY=

# Admin API key (required in production)
ADMIN_API_KEY=dev-admin-key

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# --- Stripe Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create in Stripe Dashboard → Products)
# Each paid tier needs 2 prices: flat monthly + metered overage
STRIPE_STARTER_FLAT_PRICE_ID=
STRIPE_STARTER_OVERAGE_PRICE_ID=
STRIPE_PRO_FLAT_PRICE_ID=
STRIPE_PRO_OVERAGE_PRICE_ID=
STRIPE_BUSINESS_FLAT_PRICE_ID=
STRIPE_BUSINESS_OVERAGE_PRICE_ID=
