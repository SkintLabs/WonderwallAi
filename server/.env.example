# WonderwallAi API Server — Environment Variables
# Copy to .env and fill in values

# Server
ENVIRONMENT=development          # "development" or "production"
PORT=8080

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./wonderwall_server.db
# DATABASE_URL=postgresql://user:pass@host:5432/wonderwall

# Groq API key (powers the Sentinel LLM classifier)
GROQ_API_KEY=

# Admin API key (required in production)
ADMIN_API_KEY=dev-admin-key

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
