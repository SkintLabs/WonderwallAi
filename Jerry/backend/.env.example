# ============================================================
# Jerry The Customer Service Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- AI API Keys (required to run the bot) ---
GROQ_API_KEY=your_groq_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here

# --- Pinecone Index Config ---
PINECONE_INDEX_NAME=sunsetbot-products

# --- Shopify ---
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# --- Database ---
# SQLite for local dev — no install needed!
DATABASE_URL=sqlite+aiosqlite:///./sunsetbot.db

# --- Redis ---
# Leave blank for now — we use in-memory context locally
REDIS_URL=

# --- App Config ---
ENVIRONMENT=development
SECRET_KEY=generate-a-strong-secret-key-at-least-64-chars
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=

# --- Admin ---
ADMIN_API_KEY=generate-a-strong-admin-key

# --- Optional ---
SENTRY_DSN=
